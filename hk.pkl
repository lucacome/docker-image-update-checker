amends "package://github.com/jdx/hk/releases/download/v1.40.0/hk@1.40.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.40.0/hk@1.40.0#/Builtins.pkl"

exclude = List("dist", "lib", "node_modules")

local linters = new Mapping<String, Step> {
  ["trailing-whitespace"] = Builtins.trailing_whitespace
  ["end-of-file-fixer"] = Builtins.newlines
  ["fix-smart-quotes"] = Builtins.fix_smart_quotes
  ["mixed-line-ending"] = Builtins.mixed_line_ending
  ["check-json"] = Builtins.jq
  ["pkl-lint"] = Builtins.pkl_format
  ["yamllint"] = Builtins.yamllint
  ["actionlint"] = Builtins.actionlint
  ["prettier"] = (Builtins.prettier) {
    depends = List("eslint")
  }
  ["eslint"] = Builtins.eslint
  ["markdownlint"] {
    glob = List("**/*.md")
    check = "markdownlint-cli2 {{files}}"
    fix = "markdownlint-cli2 --fix {{files}}"
  }
  ["codespell"] {
    check =
      "codespell --ignore-words-list=commitish --quiet-level=7 --skip=./dist/**,./lib/**,./node_modules/** {{files}}"
    fix =
      "codespell --ignore-words-list=commitish --quiet-level=7 --write-changes --skip=./dist/**,./lib/**,./node_modules/** {{files}}"
  }
}

local precommit = new Mapping<String, Step> {
  ["detect-private-key"] = Builtins.detect_private_key
  ["check-added-large-files"] = Builtins.check_added_large_files
  ["check-merge-conflict"] = Builtins.check_merge_conflict
  ["no-commit-to-branch"] = Builtins.no_commit_to_branch
  ["gitleaks"] {
    check = "gitleaks git --pre-commit --redact --staged --verbose --no-banner"
  }
}

local checkers = new Mapping<String, Step> {
  ["check-case-conflict"] = Builtins.check_case_conflict
  ["editorconfig-checker"] = Builtins.editorconfig_checker
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps {
      ["build"] {
        check = "mise run build"
        glob = List("**/*.ts", "package.json", "yarn.lock", "tsconfig.json", "rollup.config.ts")
        exclusive = true
      }
      ["linters"] = new Group {
        steps = linters
      }
      ["checkers"] = new Group {
        steps = checkers
      }
      ["postlint"] {
        check = "mise run postlint"
        exclusive = true
      }
      ["precommit"] = new Group {
        steps = precommit
      }
    }
  }
  ["check"] {
    steps {
      ["linters"] = new Group {
        steps = linters
      }
      ["checkers"] = new Group {
        steps = checkers
      }
    }
  }
  ["fix"] {
    fix = true
    steps {
      ...linters
    }
  }
}

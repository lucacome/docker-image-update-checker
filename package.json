{
  "author": "Luca Comellini",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@docker/actions-toolkit": "^0.93.0",
    "zod": "^4.4.3"
  },
  "description": "GitHub Action to check if a Docker image needs to be updated",
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "js-yaml": "^5.2.1",
    "prettier": "^3.9.5",
    "rollup": "^4.62.2",
    "ts-jest": "^29.4.11",
    "ts-jest-resolver": "^2.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "keywords": [
    "actions",
    "docker",
    "update"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "license": "MIT",
  "main": "src/main.ts",
  "name": "lucacome-docker-image-update-checker",
  "packageManager": "yarn@4.17.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucacome/docker-image-update-checker.git"
  },
  "scripts": {
    "all": "yarn format && yarn test && yarn build",
    "build": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "eslint": "eslint --max-warnings=0 .",
    "eslint:fix": "eslint --fix .",
    "format": "yarn run prettier:fix && yarn run eslint:fix",
    "lint": "yarn run prettier && yarn run eslint",
    "prettier": "prettier --check \"./**/*.ts\"",
    "prettier:fix": "prettier --write \"./**/*.ts\"",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest"
  },
  "type": "module"
}
